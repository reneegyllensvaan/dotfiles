#!/usr/bin/env python3
"""Generate .desktop files for Faugus Launcher games so they show up in fuzzel.

Reads ~/.config/faugus-launcher/games.json and writes one .desktop file
per (non-hidden) game to ~/.local/share/applications/.
Converts .ico icons to .png using ImageMagick (convert/magick).
"""
import json
import os
import shutil
import subprocess
import sys

GAMES_JSON = os.path.expanduser("~/.config/faugus-launcher/games.json")
APPS_DIR = os.path.expanduser("~/.local/share/applications")
ICONS_DIR = os.path.expanduser("~/.local/share/icons/hicolor/256x256/apps")


def _find_convert() -> str | None:
    for cmd in ("magick", "convert"):
        if shutil.which(cmd):
            return cmd
    return None


def _ico_to_png(ico_path: str, png_path: str) -> bool:
    """Convert .ico to .png. Returns True on success."""
    convert = _find_convert()
    if convert is None:
        return False
    # Only reconvert if source is newer
    if os.path.exists(png_path) and os.path.getmtime(png_path) >= os.path.getmtime(ico_path):
        return True
    try:
        subprocess.run(
            [convert, "-background", "none", ico_path, "-resize", "256x256", png_path],
            check=True,
            capture_output=True,
        )
        return True
    except subprocess.CalledProcessError:
        return False


def _best_icon_path(game: dict) -> str | None:
    """Return usable icon path or None."""
    icon = game.get("icon", "")
    if not icon or not os.path.exists(icon):
        return None

    # Already a format fuzzel can use
    if icon.endswith((".png", ".svg", ".xpm")):
        return icon

    # .ico -> convert to .png
    if icon.endswith(".ico"):
        gameid: str = game["gameid"]
        os.makedirs(ICONS_DIR, exist_ok=True)
        png = os.path.join(ICONS_DIR, f"faugus-{gameid}.png")
        if _ico_to_png(icon, png):
            return png

    return None


def main() -> int:
    if not os.path.exists(GAMES_JSON):
        print(f"faugus-desktop-gen: {GAMES_JSON} not found, skipping", file=sys.stderr)
        return 0

    with open(GAMES_JSON) as f:
        games = json.load(f)

    os.makedirs(APPS_DIR, exist_ok=True)
    count = 0

    for game in games:
        if game.get("hidden"):
            continue

        gameid: str = game["gameid"]
        title: str = game.get("title", gameid)
        icon = _best_icon_path(game)

        icon_line = f"Icon={icon}" if icon else "Icon=faugus-launcher"

        out_path = os.path.join(APPS_DIR, f"faugus-{gameid}.desktop")

        desktop = f"""[Desktop Entry]
Type=Application
Name={title}
Exec=faugus-run --game {gameid}
{icon_line}
Categories=Game;
StartupWMClass=faugus-launcher
"""
        try:
            with open(out_path, "w") as fh:
                fh.write(desktop)
            os.chmod(out_path, 0o755)
            count += 1
        except OSError as e:
            print(f"faugus-desktop-gen: failed to write {out_path}: {e}", file=sys.stderr)

    print(f"faugus-desktop-gen: wrote {count} .desktop files to {APPS_DIR}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
